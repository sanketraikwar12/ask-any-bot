# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# CORS - Allow these origins to call the API
# For production, add your deployed frontend URL (e.g., https://ask-any-bot.vercel.app)
ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,https://ask-any-bot.vercel.app

# Server settings
PORT=8000
TIMEOUT_SECONDS=45

# Database settings
DATABASE_PATH=ask_any_bot.db
SAVE_TO_DB=true
